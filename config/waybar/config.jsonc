// -*- mode: jsonc -*-
{
  "spacing": 4,
  "layer": "top",
  "modules-left": [
    // "hyprland/workspaces",
    "niri/workspaces",
    "tray",
  ],
  "modules-center": [
    "clock",
  ],
  "modules-right": [
    "wireplumber",
    // "pulseaudio",
    "backlight",
    "network",
    "cpu",
    "memory",
    "battery",
    "custom/powermenu"
  ],
  // Modules configuration
  "tray" :{
    "show-passive-items": true,
    "spacing": 10
  },
  "niri/workspaces": {
    "format": "{value}",
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "warp-on-scroll": false,
    "sort-by-number": true,
    "show-special": false,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "*": 3
    },
    "format": "{icon} {windows}",
    "window-rewrite-default": "пҒҷ ",
    "window-rewrite": {		
      "title<.*amazon.*>": "пү° ",
      "title<.*reddit.*>": "пҠҒ ",

      "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "оқ… ",
      "class<zen>": "у°°· ",
      "class<waterfox|waterfox-bin>": "оә“ ",
      "class<microsoft-edge>": "пҠӮ ",
      "class<Chromium|Thorium|[Cc]hrome>": "пүЁ ",
      "class<brave-browser>": "рҹҰҒ ",
      "class<tor browser>": "пҚұ ",
      "class<firefox-developer-edition>": "рҹҰҠ ",

      "class<kitty|konsole>": "оҜҶ ",
      "class<kitty-dropterm>": "п„  ",
      "class<com.mitchellh.ghostty>": "оһ• ",
      "class<org.wezfurlong.wezterm>": "оӘ… ",

      "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "пҚ° ",
      "class<eu.betterbird.Betterbird>": "пҚ° ",
      "title<.*gmail.*>": "у°Ҡ« ",

      "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "оҲ— ",
      "class<discord|[Ww]ebcord|Vesktop>": "пҮҝ ",
      "title<.*whatsapp.*>": "пҲІ ",
      "title<.*zapzap.*>": "пҲІ ",
      "title<.*messenger.*>": "пүҹ ",
      "title<.*facebook.*>": "пӮҡ ",
      "title<.*reddit.*>": "пҠҒ ",

      "title<.*Claude.*>": "у°ҡ© ",
      "title<.*ChatGPT.*>": "у°ҡ© ",
      "title<.*deepseek.*>": "у°ҡ© ",
      "title<.*qwen.*>": "у°ҡ© ",
      "class<subl>": "у°…і ",
      "class<slack>": "пҶҳ ",

      "class<mpv>": "пҚ® ",
      "class<celluloid|Zoom>": "пҖҪ ",
      "class<Cider>": "у°ҺҶ ",
      "title<.*Picture-in-Picture.*>": "п”¬ ",
      "title<.*youtube.*>": "п…Ә ",
      "class<vlc>": "у°•ј ",
      "title<.*cmus.*>": "пҖҒ ",
      "class<[Ss]potify>": "пҶј ",

      "class<virt-manager>": "оӯ» ",
      "class<.virt-manager-wrapped>": "оӯ» ",
      "class<virtualbox manager>": "рҹ’Ҫ ",
      "title<virtualbox>": "рҹ’Ҫ ",
      "class<remmina>": "рҹ–ҘпёҸ ",

      "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "у°Ёһ ",
      "class<dev.zed.Zed>": "у°өҒ",
      "class<codeblocks>": "у°…© ",
      "title<.*github.*>": "п„“ ",
      "class<mousepad>": "п…ң ",
      "class<libreoffice-writer>": "оҡҘ ",
      "class<libreoffice-startcenter>": "у°ҸҶ ",
      "class<libreoffice-calc>": "пҚ» ",
      "title<.*nvim ~.*>": "пҚҜ ",
      "title<.*vim.*>": "оҹ… ",
      "title<.*nvim.*>": "оҹ… ",
      "title<.*figma.*>": "оҪҮ ",
      "title<.*jira.*>": "оқң ",
      "class<jetbrains-idea>": "оһө ",

      "class<obs|com.obsproject.Studio>": "о®§ ",

      "class<polkit-gnome-authentication-agent-1>": "у°’ғ ",
      "class<nwg-look>": "оӯ’ ",
      "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "уұЎ« ",
      "class<steam>": "пҶ¶ ",
      "class<thunar|nemo>": "у°қ° ",	
      "class<Gparted>":"пғҮ",
      "class<gimp>": "пҢё ",
      "class<emulator>": "рҹ“ұ ",
      "class<android-studio>": "п…» ",
      "class<org.pipewire.Helvum>": "у°“ғ",
      "class<localsend>":"пҮ ",
      "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "у°№ӣ",
    }
	},
  "clock": {
   "format": "пҒі {:%m/%d/%Y - пҖ— %I:%M %p}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "пҖ— {:%I:%M %p}"
  },
  "cpu": {
    "format": "{usage}% пӢӣ ",
    "tooltip": true
  },
  "memory": {
    "format": "{}% пғү "
  },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{percent}% {icon}",
    "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "tooltip": false,
    "format": "{icon} {capacity}% уұҗҢ{power} W",
    "format-full": "{capacity}% {icon} уұҗҢ{power} W",
    "format-charging": "{capacity}% пҮҰ  {power} W",
    "format-plugged": "{capacity}% пҮҰ  {power} W",
    "format-alt": "{time} {icon} ",
    "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "пғ§",
      "performance": "пғ§",
      "balanced": "пүҺ",
      "power-saver": "пҒ¬"
    }
  },
  "network": {
    "format-wifi": "({signalStrength}%) пҮ« ",
    "format-ethernet": "пһ– ",
    "format-linked": "{ifname} (No IP) пһ– ",
    "format-disconnected": "Disconnected вҡ  ",
    "tooltip-format": "{ifname} via {gwaddr}\nEthernet: {ipaddr}/{cidr} пһ–\nWiFi: {essid} ({signalStrength}%) пҮ«",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },
  "wireplumber": {
    "format": "{volume}% {icon} {format_source} ",
    "format-bluetooth": "{volume}% {icon}пҠ” {format_source} ",
    "format-bluetooth-muted": "пҡ© {icon}пҠ” {format_source} ",
    "format-muted": "пҡ©  {format_source} ",
    "format-source": "{volume}% п„°",
    "format-source-muted": "п„ұ",
    "format-icons": {
      "headphone": "пҖҘ",
      "hands-free": "п–җ",
      "headset": "п–җ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№",
      "default": ["пҖҰ", "пҖ§", "пҖЁ"]
    },
    // "on-click": "helvum"
  },
  "pulseaudio": {
    "format": "{volume}% {icon} {format_source} ",
    "format-bluetooth": "{volume}% {icon}пҠ” {format_source} ",
    "format-bluetooth-muted": "пҡ© {icon}пҠ” {format_source} ",
    "format-muted": "пҡ©  {format_source} ",
    "format-source": "{volume}% п„°",
    "format-source-muted": "п„ұ",
    "format-icons": {
      "headphone": "пҖҘ",
      "hands-free": "п–җ",
      "headset": "п–җ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№",
      "default": ["пҖҰ", "пҖ§", "пҖЁ"]
    },
    "on-click": "pavucontrol"
  },
  "custom/powermenu": {
    "format": "у°җҘ",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/powermenu.sh"
  }
}

